# ============================================================
# .env.example — Plantilla de variables de entorno
# ============================================================
# 1. Copia este archivo como ".env"
# 2. Rellena los valores reales
# 3. NUNCA subas el archivo .env a GitHub
# ============================================================

# Token del bot (obtenido de @BotFather en Telegram)
TELEGRAM_BOT_TOKEN=tu_token_aqui

# IDs de grupos/canales (negativos para grupos)
PUBLIC_GROUP_ID=-1001234567890
VIP_GROUP_ID=-1009876543210
CHANNEL_ID=-1001112223334

# Administrador
ADMIN_USERNAME=@koooke

# Google Sheets
GOOGLE_SHEET_ID=tu_sheet_id_aqui
GOOGLE_SHEET_RANGE=Hoja1!A:I
# Ruta al JSON de service account (opcional — si no se usa, necesitas token.json por OAuth)
GOOGLE_SERVICE_ACCOUNT=ruta/al/service-account.json
